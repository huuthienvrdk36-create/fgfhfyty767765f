# FastAPI Proxy Dockerfile
FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy proxy server
COPY server.py .

# Copy admin panel dist (will be mounted in docker-compose)
RUN mkdir -p /app/admin/dist

EXPOSE 8001

CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8001"]
